// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  DOCTOR
  SECRETARY
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          UserRole  @default(DOCTOR)
  officeId      String?
  office        Office?   @relation(fields: [officeId], references: [id])
  appointments  Appointment[] @relation("DoctorAppointments")

  // Link to subscription (owner — 1:1)
  subscription  Subscription?

  // Doctor profile linked to this user (if sub-doctor)
  doctor        Doctor?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Subscription {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  phone         String
  idType        String    // e.g., DNI, Passport
  idNumber      String    @unique
  gender        String
  specialty     String

  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])

  // Doctores dados de alta desde esta suscripción
  doctors       Doctor[]

  // Especialidades configuradas en esta suscripción
  specialties   Specialty[]

  // Status: TRIAL | ACTIVE | PAST_DUE | EXPIRED
  status        String    @default("TRIAL")
  trialEndsAt   DateTime  // fecha de vencimiento del período gratuito (createdAt + 30 días)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("subscription")
}

model Specialty {
  id             String       @id @default(cuid())
  name           String

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([subscriptionId, name]) // no duplicar nombre dentro de la misma suscripción
}

model Doctor {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  specialty     String
  email         String    @unique
  phone         String

  // Subscription que lo dio de alta
  subscriptionId String
  subscription  Subscription @relation(fields: [subscriptionId], references: [id])

  // Usuario de acceso al sistema
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Office {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  users       User[]
  patients    Patient[]
  appointments Appointment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Patient {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  dni           String?  @unique
  birthDate     DateTime?
  medicalHistory String? @db.Text
  officeId      String
  office        Office   @relation(fields: [officeId], references: [id])
  appointments  Appointment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Appointment {
  id          String            @id @default(cuid())
  date        DateTime
  reason      String?
  status      AppointmentStatus @default(PENDING)
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  officeId    String
  office      Office            @relation(fields: [officeId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([doctorId])
  @@index([patientId])
  @@index([officeId])
}
